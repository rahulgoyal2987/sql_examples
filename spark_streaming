from pyspark.sql import functions as F
spark.readStream.format("delta").table("workspace.bookstore_eng_pro.dd_source").
groupBy(F.window("event_time", "60 seconds")).
count().
writeStream.format("delta").
outputMode("complete").
option("checkpointLocation","/Volumes/workspace/default/test1").
trigger(availableNow=True).toTable("dd_source1")

create streaming table dd_source_s as select * from stream(dd_source);
select window, count(*) from dd_source_s
group by window(event_time, '60 seconds')


